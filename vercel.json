{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/main.py"
    }
  ],
  "env": {
    "PROPERTY_LISTINGS_DB_PATH": "/tmp/property_listings.db",
    "ALLOWED_ORIGINS": "https://*.vercel.app,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500",
    "RATE_LIMIT_MAX": "10",
    "RATE_LIMIT_WINDOW": "60"
  }
}
