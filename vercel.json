{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/main.py"
    }
  ],
  "env": {
    "ALLOWED_ORIGINS": "https://*.vercel.app,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500",
    "ENVIRONMENT": "production",
    "RATE_LIMIT_MAX": "10",
    "RATE_LIMIT_WINDOW": "60",
    "PYTHON_VERSION": "3.12"
  }
}
