# Local development may omit DATABASE_URL and use this SQLite file.
PROPERTY_LISTINGS_DB_PATH=property_listings.db

# Production must set a managed PostgreSQL URL, for example the value supplied
# by a Vercel Marketplace Postgres provider.
DATABASE_URL=
ENVIRONMENT=development
SITE_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60
RATE_LIMIT_SECRET=
ADMIN_LOGIN_RATE_LIMIT_MAX=8
ADMIN_LOGIN_RATE_LIMIT_WINDOW=900

# Optional integrations. Leave blank to disable.
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
LEAD_FALLBACK_EMAIL=
LEAD_FROM_EMAIL=
SMTP_URL=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Admin bootstrap (use a generated Argon2 hash; never commit a plaintext password).
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
EDITOR_EMAIL=
EDITOR_PASSWORD_HASH=
SESSION_SECRET=
ADMIN_SESSION_SECONDS=3600
